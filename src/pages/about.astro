---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import SectionHeading from '../components/SectionHeading.astro';
import { site } from '../config/site';
---

<BaseLayout title="About" description="The vision, mission, and future of the Al-Ihsan Academy Alumni network.">
  <PageHero
    eyebrow="About"
    title="Bridging the gap between past and present graduates"
    subtitle="Once students graduate from 12th grade, their active contact with the school often drops as they pursue college, frequently out of town. This platform exists to keep that connection alive."
  />

  <section class="container-page py-16">
    <div class="grid gap-12 md:grid-cols-2">
      <div>
        <SectionHeading eyebrow="Vision" title="A connected alumni family" />
        <p class="prose-content mt-5">
          The primary mission is to bridge the gap between past and present graduates of
          {' '}{site.school}. We want to build a solid, deeply connected alumni network, one that
          keeps alumni engaged with the ISNS community, grounded in their faith, and fostering
          peer-to-peer mentorship.
        </p>
      </div>
      <div>
        <SectionHeading eyebrow="Mission" title="Engage, ground, and mentor" />
        <p class="prose-content mt-5">
          Through a monthly newsletter and this companion website, we keep alumni informed and
          involved. Over time, this platform could grow to explore community matrimonial
          matchmaking, job assistance, and technical peer support, all in service of the ummah.
        </p>
      </div>
    </div>
  </section>

  <section class="bg-cream-200/60 py-16">
    <div class="container-page">
      <SectionHeading eyebrow="Who it's for" title="Target audience" align="center" />
      <p class="mx-auto mt-6 max-w-2xl text-center text-lg text-ink/80">
        Past and present senior class students of Al-Ihsan Academy: <strong>Grades 9 through 12</strong>.
        Subscription is, and always will be, <strong>completely free</strong>. No payment is ever
        required to join or to keep your alumni status active.
      </p>
    </div>
  </section>

  <section class="container-page py-16">
    <SectionHeading eyebrow="The Newsletter" title="What we cover each month" />
    <div class="prose-content mt-6 max-w-none">
      <ul class="grid gap-4 sm:grid-cols-2">
        <li><strong>ISNS Updates:</strong> key community news and events.</li>
        <li><strong>Physical Perspective of the Quran:</strong> Quran museums, calligraphy, and the physical aspects of the Quran.</li>
        <li><strong>Alumni Insights:</strong> campus experiences, achievements, and advice from college-aged alumni.</li>
        <li><strong>Expert Q&A:</strong> questions answered by local Muftis and scholars.</li>
        <li><strong>Question of the Month:</strong> interactive trivia and reflection, with winners announced each issue.</li>
        <li><strong>Future growth:</strong> matrimonial matchmaking, job assistance, and technical peer support, in shaa Allah.</li>
      </ul>
    </div>
  </section>

  <section class="pattern-bg text-white">
    <div class="container-page py-14 text-center">
      <h2 class="font-display text-3xl text-white">Be part of it</h2>
      <p class="mx-auto mt-3 max-w-xl text-cream-100/90">
        Register your details and help us build a network that lasts a lifetime.
      </p>
      <a href="/register" class="btn-primary mt-6">Register for free</a>
    </div>
  </section>
</BaseLayout>
