---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
---

<BaseLayout
  title="Thank You"
  description="Thank you for your submission to the Al-Ihsan Academy Alumni network."
>
  <PageHero
    eyebrow="Received"
    title="Jazak Allahu khayran!"
    subtitle="Your submission was received. We read every response, in shaa Allah."
  />

  <section class="container-page py-16">
    <div class="mx-auto max-w-xl card text-center">
      <p class="text-5xl">📬</p>
      <h2 id="ty-message" class="mt-4 text-2xl text-emerald-800">Thank you for getting involved.</h2>
      <p class="mt-3 text-ink/75">
        We've recorded your response. If you asked us to follow up, we'll be in touch.
      </p>
      <div class="mt-8 flex flex-wrap justify-center gap-3">
        <a href="/" class="btn-secondary">Back to home</a>
        <a href="/get-involved" class="btn-primary">Submit something else</a>
      </div>
    </div>
  </section>

  <!-- Tailors the message to whichever form was submitted (?form=...). -->
  <script is:inline>
    (function () {
      const messages = {
        register: 'Welcome to the alumni network!',
        expertQa: 'Your question has been sent to the scholars.',
        questionOfMonth: 'Your answer is in — winners are announced next issue, in shaa Allah.',
        alumniUpdate: 'Thank you for sharing your story.',
      };
      const form = new URLSearchParams(window.location.search).get('form');
      if (form && messages[form]) {
        const el = document.getElementById('ty-message');
        if (el) el.textContent = messages[form];
      }
    })();
  </script>
</BaseLayout>
