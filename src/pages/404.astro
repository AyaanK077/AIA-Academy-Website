---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Page not found">
  <section class="pattern-bg text-white">
    <div class="container-page py-28 text-center">
      <p class="font-arabic text-2xl text-gold-300">إنا لله</p>
      <h1 class="mt-4 font-display text-6xl text-white">404</h1>
      <p class="mt-4 text-cream-100/90">We couldn't find that page.</p>
      <a href="/" class="btn-primary mt-8">Return home</a>
    </div>
  </section>
</BaseLayout>
