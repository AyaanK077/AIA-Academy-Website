---
interface Props {
  eyebrow?: string;
  title: string;
  align?: 'left' | 'center';
}
const { eyebrow, title, align = 'left' } = Astro.props;
---

<div class={align === 'center' ? 'text-center' : ''}>
  {eyebrow && <p class="eyebrow">{eyebrow}</p>}
  <h2 class="mt-2 text-3xl md:text-4xl">{title}</h2>
  <div class={`mt-3 h-1 w-16 rounded bg-gold-500 ${align === 'center' ? 'mx-auto' : ''}`}></div>
</div>
