---
interface Props {
  title: string;
  issue?: string;
  date: Date;
  summary: string;
  slug: string;
  pdf?: string;
}
const { title, issue, date, summary, slug, pdf } = Astro.props;
const dateStr = date.toLocaleDateString('en-US', { year: 'numeric', month: 'long' });
---

<article class="card flex flex-col">
  <div class="flex items-center justify-between gap-3">
    <span class="text-xs font-semibold uppercase tracking-widest text-gold-600">
      {issue ?? dateStr}
    </span>
    {pdf && (
      <span class="rounded-full bg-emerald-50 px-2 py-1 text-xs font-medium text-emerald-700">PDF</span>
    )}
  </div>
  <h3 class="mt-2 text-xl">
    <a href={`/newsletters/${slug}`} class="hover:text-gold-600">{title}</a>
  </h3>
  <p class="mt-2 flex-1 text-sm text-ink/75">{summary}</p>
  <div class="mt-4 flex flex-wrap gap-3">
    <a href={`/newsletters/${slug}`} class="btn-secondary px-4 py-2 text-sm">Read</a>
    {pdf && (
      <a href={pdf} target="_blank" rel="noopener" class="btn-primary px-4 py-2 text-sm">Download PDF</a>
    )}
  </div>
</article>
