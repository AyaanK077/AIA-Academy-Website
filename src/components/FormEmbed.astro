---
import { forms, formIsConfigured } from '../config/site';

interface Props {
  // key into the `forms` object in src/config/site.ts
  form: keyof typeof forms;
  title: string;
  height?: number;
}
const { form, title, height = 1100 } = Astro.props;
const link = forms[form];
const ready = formIsConfigured(link);
---

{ready ? (
  <div class="overflow-hidden rounded-2xl border border-cream-300 bg-white shadow-sm">
    <iframe
      src={link.embedUrl}
      title={title}
      width="100%"
      height={height}
      frameborder="0"
      marginheight={0}
      marginwidth={0}
      loading="lazy"
      class="w-full"
    >
      Loading…
    </iframe>
  </div>
) : (
  <div class="rounded-2xl border-2 border-dashed border-gold-300 bg-cream-50 p-10 text-center">
    <p class="font-display text-2xl text-emerald-800">Form coming soon</p>
    <p class="mx-auto mt-3 max-w-md text-ink/70">
      This form has not been connected yet. The site editor can add the Google Form
      link in <code class="rounded bg-cream-200 px-1">src/config/site.ts</code> (see the README).
    </p>
  </div>
)}

{ready && link.shareUrl && link.shareUrl !== 'REPLACE_ME' && (
  <p class="mt-4 text-center text-sm text-ink/60">
    Trouble seeing the form?
    <a href={link.shareUrl} target="_blank" rel="noopener" class="text-emerald-700 underline">
      Open it in a new tab
    </a>.
  </p>
)}
