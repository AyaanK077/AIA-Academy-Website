---
// -----------------------------------------------------------------------------
// NetlifyForm.astro
// Native, on-site submission forms powered by **Netlify Forms** (free, built in
// to Netlify hosting). No Google account needed for visitors. Submissions show
// up in your Netlify dashboard under "Forms", and Netlify can email you on every
// new submission (Netlify dashboard → Forms → Settings & notifications).
//
// To ADD or CHANGE a question, edit the `FORMS` object below. Each field becomes
// a labelled input. The `name` of each field is the column you'll see in Netlify.
// -----------------------------------------------------------------------------

type Field = {
  name: string;
  label: string;
  type: 'text' | 'email' | 'textarea' | 'radio' | 'select' | 'file';
  required?: boolean;
  placeholder?: string;
  help?: string;
  options?: string[]; // for radio / select
};

type FormDef = {
  title: string;
  intro?: string;
  fields: Field[];
};

const CONSENT = ['Yes, with my name', 'Yes, anonymously'];

const FORMS: Record<string, FormDef> = {
  register: {
    title: 'Alumni Registration',
    intro: 'Free, always. We never share your information.',
    fields: [
      { name: 'name', label: 'Full name', type: 'text', required: true },
      { name: 'email', label: 'Email address', type: 'email', required: true },
      { name: 'grad_year', label: 'Graduation year (or expected)', type: 'text', required: true, placeholder: 'e.g. 2021' },
      { name: 'status', label: 'Are you a current student or graduate?', type: 'radio', required: true, options: ['Current student', 'Graduate'] },
      { name: 'college', label: 'College / University', type: 'text', help: 'If applicable.' },
      { name: 'field_of_study', label: 'Field of study or profession', type: 'text' },
      { name: 'location', label: 'City / State', type: 'text' },
      { name: 'mentor', label: 'Would you like to mentor younger alumni?', type: 'radio', options: ['Yes', 'No', 'Maybe later'] },
      { name: 'notes', label: 'Anything else you would like us to know?', type: 'textarea' },
    ],
  },
  expertQa: {
    title: 'Ask the Experts',
    intro: 'Questions are answered by qualified Muftis and scholars. Please keep them respectful and concise.',
    fields: [
      { name: 'name', label: 'Your name', type: 'text', placeholder: 'Leave blank to stay anonymous' },
      { name: 'email', label: 'Email address', type: 'email', help: 'Optional — only used if we need to follow up.' },
      { name: 'grad_year', label: 'Graduation year', type: 'text' },
      { name: 'question', label: 'Your question', type: 'textarea', required: true },
      { name: 'category', label: 'Category', type: 'select', options: ['Fiqh', 'Aqeedah', 'Daily life', 'College & faith', 'Other'] },
      { name: 'publish_consent', label: 'May we publish this question?', type: 'radio', required: true, options: ['Yes, with my name', 'Yes, anonymously', 'Please ask me first'] },
    ],
  },
  questionOfMonth: {
    title: 'Question of the Month',
    intro: "Answer this month's question for a chance to be featured in the next newsletter, in shaa Allah.",
    fields: [
      { name: 'name', label: 'Full name', type: 'text', required: true },
      { name: 'email', label: 'Email address', type: 'email', help: 'Optional — so we can let you know if you win.' },
      { name: 'grad_year', label: 'Graduation year', type: 'text' },
      { name: 'answer', label: 'Your answer', type: 'textarea', required: true },
      { name: 'publish_consent', label: 'May we publish your answer if selected?', type: 'radio', required: true, options: CONSENT },
    ],
  },
  alumniUpdate: {
    title: 'Share Your Story',
    intro: 'Tell us about your campus experience, achievements, or advice. Selected stories appear in Alumni Insights.',
    fields: [
      { name: 'name', label: 'Full name', type: 'text', required: true },
      { name: 'email', label: 'Email address', type: 'email', help: 'Optional — only used if we need to follow up.' },
      { name: 'grad_year', label: 'Graduation year', type: 'text', required: true },
      { name: 'college', label: 'College / University & major', type: 'text' },
      { name: 'story', label: "What's your update or story?", type: 'textarea', required: true },
      { name: 'advice', label: 'Advice for current AIA students', type: 'textarea' },
      { name: 'publish_consent', label: 'May we publish this?', type: 'radio', required: true, options: ['Yes, with my name', 'Yes, anonymously', 'No, just FYI'] },
      { name: 'photo', label: 'Upload a photo (optional)', type: 'file', help: 'A clear photo we may publish alongside your story.' },
    ],
  },
};

interface Props {
  // which form to render — key into FORMS above
  form: keyof typeof FORMS;
  // kept for backwards compatibility with the old embed component (ignored)
  title?: string;
  height?: number;
}

const { form } = Astro.props;
const def = FORMS[form];
const hasFile = def.fields.some((f) => f.type === 'file');

const inputClass =
  'w-full rounded-xl border border-cream-300 bg-white px-4 py-3 text-ink shadow-sm transition-colors placeholder:text-ink/40 focus:border-emerald-500 focus:outline-none focus:ring-2 focus:ring-emerald-200';
---

<form
  name={form}
  method="POST"
  action={`/thank-you/?form=${form}`}
  data-netlify="true"
  netlify-honeypot="bot-field"
  enctype={hasFile ? 'multipart/form-data' : undefined}
  class="card space-y-6"
>
  {/* Netlify needs this hidden field to match submissions to the form name. */}
  <input type="hidden" name="form-name" value={form} />
  {/* Honeypot: real people never see/fill this; bots that do get filtered out. */}
  <p class="hidden">
    <label>Don’t fill this out if you’re human: <input name="bot-field" /></label>
  </p>

  {def.fields.map((f) => (
    <div>
      <label class="block text-sm font-medium text-emerald-800" for={f.name}>
        {f.label}
        {f.required && <span class="text-gold-600"> *</span>}
      </label>

      {f.help && <p class="mt-1 text-xs text-ink/55">{f.help}</p>}

      {f.type === 'textarea' ? (
        <textarea id={f.name} name={f.name} required={f.required} rows={5} placeholder={f.placeholder} class={`mt-2 ${inputClass}`}></textarea>
      ) : f.type === 'select' ? (
        <select id={f.name} name={f.name} required={f.required} class={`mt-2 ${inputClass}`}>
          <option value="" disabled selected>Choose one…</option>
          {f.options!.map((o) => <option value={o}>{o}</option>)}
        </select>
      ) : f.type === 'radio' ? (
        <div class="mt-2 space-y-2">
          {f.options!.map((o, i) => (
            <label class="flex items-center gap-3 rounded-xl border border-cream-300 bg-cream-50 px-4 py-2.5 cursor-pointer hover:border-gold-400">
              <input type="radio" name={f.name} value={o} required={f.required && i === 0} class="h-4 w-4 accent-emerald-700" />
              <span class="text-sm text-ink/90">{o}</span>
            </label>
          ))}
        </div>
      ) : f.type === 'file' ? (
        <input id={f.name} name={f.name} type="file" accept="image/*" class="mt-2 block w-full text-sm text-ink/80 file:mr-4 file:rounded-full file:border-0 file:bg-emerald-700 file:px-4 file:py-2 file:text-sm file:font-medium file:text-white hover:file:bg-emerald-800" />
      ) : (
        <input id={f.name} name={f.name} type={f.type} required={f.required} placeholder={f.placeholder} class={`mt-2 ${inputClass}`} />
      )}
    </div>
  ))}

  <div class="pt-2">
    <button type="submit" class="btn-primary w-full sm:w-auto">Submit</button>
    <p class="mt-3 text-xs text-ink/55">
      Your information is kept private and never shared. Fields marked
      <span class="text-gold-600">*</span> are required.
    </p>
  </div>
</form>
